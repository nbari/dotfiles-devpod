#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

zinit_home="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
zinit_repo="https://github.com/zdharma-continuum/zinit.git"

mkdir -p "$(dirname "${zinit_home}")"

if [ ! -d "${zinit_home}/.git" ]; then
  git clone --depth=1 "${zinit_repo}" "${zinit_home}" || exit 0
  exit 0
fi

if [ -n "$(git -C "${zinit_home}" status --porcelain 2>/dev/null)" ]; then
  exit 0
fi

git -C "${zinit_home}" pull --ff-only --quiet || exit 0
