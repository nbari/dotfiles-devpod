# ----------------------------------------------------------------------------
# PATH
# ----------------------------------------------------------------------------
typeset -U path PATH

typeset -a system_path_defaults=(
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
)

typeset -a path_entries=(
  "$HOME/.local/bin"
)

if [ -d "$HOME/.local/share/pnpm" ]; then
  export PNPM_HOME="$HOME/.local/share/pnpm"
  path_entries+=("$PNPM_HOME")
fi

if [ -d "$HOME/.cargo/bin" ]; then
  path_entries+=("$HOME/.cargo/bin")
fi

if [ -d "$HOME/.luarocks/bin" ]; then
  path_entries+=("$HOME/.luarocks/bin")
fi

if [ -d /snap/bin ]; then
  path_entries+=(/snap/bin)
fi

path=(
  $path_entries
  $system_path_defaults
  $path
)
unset path_entries system_path_defaults

export EDITOR="nvim"
export VISUAL="nvim"

podman_socket="/run/user/$(id -u)/podman/podman.sock"
if [ -z "${DOCKER_HOST:-}" ] && [ "$(uname -s)" = "Linux" ] && [ -S "$podman_socket" ]; then
  export DOCKER_HOST="unix://${podman_socket}"
fi
unset podman_socket

# ----------------------------------------------------------------------------
# mise
# ----------------------------------------------------------------------------
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# ----------------------------------------------------------------------------
# direnv
# ----------------------------------------------------------------------------
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# ----------------------------------------------------------------------------
# zsh functions path
# ----------------------------------------------------------------------------
fpath+=${ZDOTDIR:-~}/.zsh_functions

# ----------------------------------------------------------------------------
# zinit
# ----------------------------------------------------------------------------
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [ -f "${ZINIT_HOME}/zinit.zsh" ]; then
  source "${ZINIT_HOME}/zinit.zsh"
  autoload -Uz compinit && compinit
  autoload -Uz _zinit
  (( ${+_comps} )) && _comps[zinit]=_zinit

  zinit for \
      atload"zicompinit; zicdreplay" \
      blockf \
      lucid \
      wait \
      zsh-users/zsh-completions

  if [[ -n $DISPLAY || -n $WAYLAND_DISPLAY ]] && \
     (command -v wl-copy >/dev/null 2>&1 || command -v xclip >/dev/null 2>&1 || command -v xsel >/dev/null 2>&1); then
      zinit light kutsan/zsh-system-clipboard
  fi

  zinit light zsh-users/zsh-syntax-highlighting
fi

(( ${+ZSH_HIGHLIGHT_STYLES} )) || typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[path]=none
ZSH_HIGHLIGHT_STYLES[path_prefix]=none

# ----------------------------------------------------------------------------
# fzf
# ----------------------------------------------------------------------------
if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi

# ----------------------------------------------------------------------------
# Load additional configurations from .zshrc.d
# ----------------------------------------------------------------------------
if [ -d "$HOME/.zshrc.d" ]; then
  for config in "$HOME/.zshrc.d"/*.zsh(N); do
    source "$config"
  done
fi

# ----------------------------------------------------------------------------
# Baseline aliases
# ----------------------------------------------------------------------------
if (( ${+commands[eza]} )); then
  LS_COMMAND="eza"
else
  LS_COMMAND="ls"
fi

if [[ "$LS_COMMAND" == "ls" ]]; then
  alias l="ls -lah"
  alias ll="ls -alF"
  alias la="ls -A"
else
  alias ls="$LS_COMMAND"
  alias l="$LS_COMMAND -l --all --group-directories-first --git"
  alias ll="$LS_COMMAND -l --all --all --group-directories-first --git"
  alias lt="$LS_COMMAND --icons -T --git-ignore --level=2 --group-directories-first"
  alias llt="$LS_COMMAND --icons -lT --git-ignore --level=2 --group-directories-first"
  alias lT="$LS_COMMAND --icons -T --git-ignore --level=4 --group-directories-first"
  alias llm="$LS_COMMAND -lbGF --git --sort=modified"
  alias la="$LS_COMMAND -lbhHigUmuSa --time-style=long-iso --git --color-scale"
  alias lx="$LS_COMMAND -lbhHigUmuSa@ --time-style=long-iso --git --color-scale"
fi
unset LS_COMMAND
